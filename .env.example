# 复制为 .env 后填值；.env 已被 .gitignore 忽略，切勿提交真实密钥。

# Python 智能层调用的 LLM（DeepSeek，OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# M2 切片② L3 model-switch：主模型失败后切到的备用模型
DEEPSEEK_FALLBACK_MODEL=deepseek-reasoner

# M2 切片② Failure/Recovery —— 智能层 L1 retry
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_MS=500
LLM_CALL_TIMEOUT_S=30
# 路由/反思用更短超时，失败快速降级，不占主任务预算
LLM_ROUTE_TIMEOUT_S=8
LLM_REFLECT_TIMEOUT_S=10

# M2 切片③ Control Node：reflect->worker 有界循环上限（默认 1，judge 宽松放行）
MAX_LOOPS=1

# M2 切片② Failure/Recovery —— Orchestrator(Go) 对瞬时 gRPC 错误重试
ORCH_MAX_RETRIES=2
ORCH_RETRY_BACKOFF_MS=300

# 服务地址（gRPC）
AGENT_RUNTIME_ADDR=127.0.0.1:9100
TOOL_SERVICE_ADDR=127.0.0.1:9200
ORCHESTRATOR_ADDR=127.0.0.1:9300
GATEWAY_HTTP_ADDR=0.0.0.0:8000

# M3 Observability：trace-store 服务（链路持久化）
TRACE_STORE_ADDR=127.0.0.1:9400
# M6-B：trace 落盘从 JSONL 换成 SQLite（可查询/可统计），此为 .db 文件路径
TRACE_STORE_FILE=data/traces.db
TRACE_STORE_MAX_OUTPUT=4096

# M3 Policy 执行防火墙（请求前置 Allow/Deny/Transform）
POLICY_FILE=configs/policy.yaml

# M6-B② Gateway 鉴权 + 限流（authz 包加载；api_keys 留空则鉴权关、仅默认限流）
AUTH_FILE=configs/auth.yaml

# M4 外部能力中间件：逗号分隔的外部工具服务 base URL（套 /spec+/invoke 薄壳的 OSS）
# 例：AI 合约审计器 auditserver
EXTERNAL_TOOLS=http://127.0.0.1:9500

# M6-C② 运行时指标观测：orchestrator 的 Prometheus /metrics 端口
METRICS_ADDR=:9301
# LLM 成本估算单价（USD / 每百万 token，默认 deepseek-chat 牌价，仅估算用，可改）
LLM_PRICE_PROMPT_USD_PER_1M=0.27
LLM_PRICE_COMPLETION_USD_PER_1M=1.10

# M7-0 pyagent 优雅停机:SIGTERM 后给 in-flight 请求的收尾秒数(compose stop_grace_period 应 >= 此值)
AGENT_RUNTIME_STOP_GRACE_S=5

# M7-1 路由能力档案(per-route 的 model/temperature/max_tokens,软约束)
ROUTE_PROFILES_FILE=configs/route-profiles.yaml
